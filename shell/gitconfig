[alias]
	ba = branch -a
	branch-current = rev-parse --symbolic-full-name --abbrev-ref HEAD
	ci = commit -v -a
	co = checkout
	forget = update-index --assume-unchanged
	dft = difftool -t difftastic
	fza = "!git ls-files -m -o --exclude-standard | fzf -m --print0 | xargs -0 git add"
	gone = "!f() { git fetch --all --prune; git branch -vv | awk '/: gone]/{print $1}' | xargs git branch -D; }; f"
	lg = log --graph --pretty=format:'%C(red)%h%Creset — %C(yellow)%s%Creset %d%n          %an, %C(green)(%ar)%Creset'
	number-of-commits-since-master = "! sh -c 'git log master..`git branch-current` --oneline | wc -l | tr -d \" \"'"
	remember = update-index --no-assume-unchanged
	root = rev-parse --show-toplevel
	rs = reset --hard HEAD
	resign = "!f() { git rebase --exec 'git commit --amend --no-edit -S' ${1:-$(git merge-base HEAD origin/HEAD)}; }; f"
	squash = "! sh -c 'git rebase --interactive HEAD~`git number-of-commits-since-master`'"
	st = status
	unmerged-add = "!f() { git ls-files --unmerged | cut -f2 | sort -u ; }; git add `f`"
	unmerged-edit = "!f() { git ls-files --unmerged | cut -f2 | sort -u ; }; vim `f`"
[apply]
	whitespace = nowarn
[branch]
	autosetupmerge = true
[color]
	branch = auto
	diff = auto
	status = auto
[color "branch"]
	current = red reverse
	local = red bold
	remote = yellow
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = magenta
[push]
	default = current
	autoSetupRemote = true
[filter "media"]
	required = true
	clean = git media clean %f
	smudge = git media smudge %f
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	required = true
	process = git-lfs filter-process
[core]
	pager = delta
	excludesFile = ~/.gitignore
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true    # use n and N to move between diff sections
	light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
[difftool]
	prompt = false
[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"
[user]
	name = Dan Brubaker Horst
	email = dan.brubaker.horst@gmail.com
	signingkey = /Users/dbh/.ssh/id_ed25519.pub
[clone]
	defaultRemoteName = origin
[init]
	defaultBranch = main
[pull]
	autoSetupRemote = true
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = /Users/dbh/.ssh/allowed_signers
