#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "Usage: json-sort FILE [FILE ...]"
  echo ""
  echo "Sort JSON object keys alphabetically in place with jq -S."
}

file_mode() {
  if stat -c "%a" "$1" >/dev/null 2>&1; then
    stat -c "%a" "$1"
  else
    stat -f "%Lp" "$1"
  fi
}

sort_json_file() {
  local input_path="$1"
  local target_path
  local target_directory
  local target_name
  local tmp_path
  local mode

  if [ ! -f "$input_path" ]; then
    echo "ERROR: Not a file: $input_path" >&2
    return 1
  fi

  target_path="$(realpath "$input_path")"
  target_directory="$(dirname "$target_path")"
  target_name="$(basename "$target_path")"
  tmp_path="$(mktemp "$target_directory/.$target_name.json-sort.XXXXXX")"

  if ! jq -S . "$target_path" >"$tmp_path"; then
    rm -f "$tmp_path"
    return 1
  fi

  mode="$(file_mode "$target_path")"
  chmod "$mode" "$tmp_path"
  mv "$tmp_path" "$target_path"
}

if [ "$#" -eq 0 ]; then
  usage >&2
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

if ! command -v jq >/dev/null 2>&1; then
  echo "ERROR: jq not found" >&2
  exit 127
fi

if ! command -v realpath >/dev/null 2>&1; then
  echo "ERROR: realpath not found" >&2
  exit 127
fi

for input_path in "$@"; do
  sort_json_file "$input_path"
done
