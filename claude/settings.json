{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/git/danhorst/dotfiles/claude/scripts/sync-tool-prefs-memory.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -z \"$f\" ] && exit 0; if echo \"$f\" | grep -qE '\\.(sh|bash|zsh)$' || head -1 \"$f\" 2>/dev/null | grep -qE '^#!.*\\b(bash|sh|zsh)\\b'; then shellcheck \"$f\"; fi; } 2>/dev/null || true",
            "statusMessage": "Running shellcheck..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "theme": "dark-daltonized"
}
