#!/usr/bin/env bash
# yp3 — Download a YouTube video as MP3
# Usage: yp3 <url> [output_dir]

set -euo pipefail

for cmd in yt-dlp ffmpeg deno; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd is not installed. Instll with \`brew install $cmd\`"
    exit 1
  fi
done

URL="${1:-}"
OUTPUT_DIR="${2:-.}"

if [[ -z "$URL" ]]; then
  echo "Usage: $0 <youtube-url> [output_dir]"
  exit 1
fi

yt-dlp \
  --extract-audio \
  --audio-format mp3 \
  --audio-quality 0 \
  --embed-thumbnail \
  --embed-metadata \
  --output "${OUTPUT_DIR}/%(title)s.%(ext)s" \
  "$URL"
