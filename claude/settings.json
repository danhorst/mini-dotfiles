{
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -z \"$f\" ] && exit 0; if echo \"$f\" | grep -qE '\\.(sh|bash|zsh)$' || head -1 \"$f\" 2>/dev/null | grep -qE '^#!.*\\b(bash|sh|zsh)\\b'; then shellcheck \"$f\"; fi; } 2>/dev/null || true",
            "statusMessage": "Running shellcheck...",
            "type": "command"
          },
          {
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -z \"$f\" ] && exit 0; echo \"$f\" | grep -qE '\\.claude/settings(\\.local)?\\.json$' || exit 0; tmp=$(mktemp); jq '.permissions.allow |= sort' \"$f\" > \"$tmp\" && mv \"$tmp\" \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Sorting permissions...",
            "type": "command"
          },
          {
            "command": "md-format-check.sh",
            "statusMessage": "Checking markdown formatting...",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "tool-prefs-check.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "seed-memory.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(ast-grep *)",
      "Bash(bat *)",
      "Bash(cement-memory.sh *)",
      "Bash(chmod *)",
      "Bash(difft *)",
      "Bash(fd *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(launchctl *)",
      "Bash(mdfnt *)",
      "Bash(mdfootnote *)",
      "Bash(mdinline *)",
      "Bash(mdjoin *)",
      "Bash(mdref *)",
      "Bash(mdsidenote *)",
      "Bash(mdsplit *)",
      "Bash(mdtable *)",
      "Bash(mdunwrap *)",
      "Bash(mdwrap *)",
      "Bash(mise *)",
      "Bash(rg *)",
      "Bash(scc *)",
      "Bash(sd *)",
      "Bash(shasum *)",
      "Bash(shellcheck *)",
      "Bash(ssh *)",
      "Bash(ssh-add *)",
      "Bash(tar *)",
      "Bash(tv *)",
      "Bash(watchexec *)",
      "Bash(xattr *)",
      "Bash(yq *)",
      "Read(//private/tmp/**)",
      "Read(//tmp/**)",
      "Skill(update-config)",
      "WebFetch(domain:github.com)"
    ],
    "defaultMode": "auto"
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized"
}
