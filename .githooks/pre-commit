#!/usr/bin/env bash
set -euo pipefail

# Block commits that violate the conventions enforced at edit-time by the
# PostToolUse hooks in claude/settings.json. On failure, print a fix command.

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM)
[[ ${#staged[@]} -eq 0 ]] && exit 0

fail=0

is_shell_script() {
  local f="$1"
  case "$f" in
    *.sh|*.bash|*.zsh) return 0 ;;
  esac
  [[ -f "$f" ]] || return 1
  head -1 "$f" 2>/dev/null | grep -qE '^#!.*\b(bash|sh|zsh)\b'
}

for f in "${staged[@]}"; do
  [[ -f "$f" ]] || continue
  if is_shell_script "$f"; then
    shellcheck "$f" || fail=1
    claude/bin/bin-shadow-check.sh "$f" || fail=1
  fi
done

for f in "${staged[@]}"; do
  case "$f" in
    claude/settings.json|claude/settings.local.json) ;;
    *) continue ;;
  esac
  [[ -f "$f" ]] || continue
  if ! diff -q <(jq '.permissions.allow' "$f") <(jq '.permissions.allow | sort' "$f") > /dev/null; then
    echo "Pre-commit: $f .permissions.allow is unsorted."
    echo "  Fix: tmp=\$(mktemp) && jq '.permissions.allow |= sort' $f > \"\$tmp\" && mv \"\$tmp\" $f"
    fail=1
  fi
done

if command -v mdsplit > /dev/null && command -v mdtable > /dev/null; then
  for f in "${staged[@]}"; do
    case "$f" in
      *.md|*.markdown) ;;
      *) continue ;;
    esac
    [[ -f "$f" ]] || continue
    tmp=$(mktemp)
    if mdsplit "$f" 2>/dev/null | mdtable 2>/dev/null > "$tmp" && [[ -s "$tmp" ]]; then
      if ! diff --brief "$tmp" "$f" > /dev/null 2>&1; then
        echo "Pre-commit: $f would change under mdsplit | mdtable."
        echo "  Fix: mdsplit \"$f\" | mdtable -i \"$f\""
        fail=1
      fi
    fi
    rm -f "$tmp"
  done
fi

# Memory seeds: validate the corpus whenever any seed is staged. memory-index.sh
# regenerates the index but never checks it, so malformed seeds fail silently.
for f in "${staged[@]}"; do
  case "$f" in
    claude/memory/*.md) claude/bin/memory-lint.sh || fail=1; break ;;
  esac
done

# Skills must not hardcode the dotfiles checkout path (feedback_skill_path_resolution).
for f in "${staged[@]}"; do
  case "$f" in
    claude/commands/*.md) ;;
    *) continue ;;
  esac
  [[ -f "$f" ]] || continue
  if rg --fixed-strings --quiet 'git/danhorst/dotfiles' "$f"; then
    echo "Pre-commit: $f hardcodes a dotfiles checkout path."
    echo "  Fix: resolve dynamically — CLAUDE_ROOT=\"\$(dirname \"\$(readlink ~/.claude/commands)\")\""
    fail=1
  fi
done

exit $fail
